{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recomputableevidence.example/schemas/fork_proof_surface_state_v0_1.schema.json",
  "title": "Fork Canonical Proof-Surface State v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "state_version",
    "state_classification",
    "as_of_date",
    "repository",
    "current_public_review_round",
    "current_recomputation_surface",
    "current_experimental_phase",
    "hypothesis_expression",
    "surfaces",
    "known_limitations",
    "invariant_non_claims"
  ],
  "properties": {
    "state_version": {
      "const": "v0.1"
    },
    "state_classification": {
      "const": "canonical_proof_surface_state"
    },
    "as_of_date": {
      "type": "string",
      "format": "date"
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "current_public_review_round": {
      "type": "string",
      "pattern": "^round-[0-9]{3}$"
    },
    "current_recomputation_surface": {
      "type": "string",
      "minLength": 1
    },
    "current_experimental_phase": {
      "type": "string",
      "minLength": 1
    },
    "hypothesis_expression": {
      "const": "E[U | H = 1] < E[U | H = 0]"
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "surface_id",
          "implementation_status",
          "schema_status",
          "schema_enforcement_status",
          "external_recomputation_status",
          "required_artifacts"
        ],
        "properties": {
          "surface_id": {
            "type": "string",
            "minLength": 1
          },
          "implementation_status": {
            "enum": [
              "implemented",
              "partially_implemented",
              "protocol_only",
              "preregistered_scaffold",
              "not_started"
            ]
          },
          "schema_status": {
            "type": "string",
            "minLength": 1
          },
          "schema_enforcement_status": {
            "type": "string",
            "minLength": 1
          },
          "external_recomputation_status": {
            "type": "string",
            "minLength": 1
          },
          "required_artifacts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "known_limitations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "limitation_id",
          "status",
          "summary"
        ],
        "properties": {
          "limitation_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "invariant_non_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
