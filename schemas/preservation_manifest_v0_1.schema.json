{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.org/schemas/preservation_manifest_v0_1.schema.json",
  "title": "Fork Preservation Manifest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_id", "schema_version", "incident_id", "status", "specimens", "historical_rewrite_authority", "checker"],
  "properties": {
    "manifest_id": {"type": "string", "minLength": 1},
    "schema_version": {"const": "0.1"},
    "incident_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["PROPOSED_FOR_ADMISSION", "ADMITTED"]},
    "specimens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["specimen_id", "original_path", "archive_path", "source_commit", "git_blob_sha1", "sha256", "media_type", "archive_execution_state", "live_path_reintroduction_prohibited"],
        "properties": {
          "specimen_id": {"type": "string", "minLength": 1},
          "original_path": {"type": "string", "minLength": 1},
          "archive_path": {"type": "string", "minLength": 1},
          "source_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
          "git_blob_sha1": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "media_type": {"type": "string", "minLength": 1},
          "archive_execution_state": {"const": "INERT_DATA_ONLY"},
          "live_path_reintroduction_prohibited": {"const": true}
        }
      }
    },
    "historical_rewrite_authority": {"const": "NONE"},
    "checker": {"const": "tools/check_preservation_integrity_v0_1.py"}
  }
}
