{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fork.recomputableevidence.dev/schemas/fork_controlled_vocabulary_v0_1.schema.json",
  "title": "Fork Controlled Vocabulary v0.1.1",
  "description": "Fork-native engineering vocabulary for evidence-boundary preservation. This schema encodes system assertions, claim reference/support distinctions, handoff events, provenance references, structural check states, recomputation states, record persistence declarations, boundary behaviors, structural outcomes, aggregate postures, aggregate-posture precedence rules, and non-claims. It does not encode or determine legal sufficiency, admissibility, legal chain of custody, legal hold, retention-law compliance, authority validity, intellectual-property license, reliance, representation, or truth.",
  "$comment": "CLAIM means a bounded statement asserted by a system, actor, model, workflow, or artifact about a subject. It does not mean a legal claim, insurance claim, patent claim, cause of action, demand, entitlement, or assertion of legal right. This schema is structural-only and non-legal.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "vocabulary_id",
    "schema_version",
    "status",
    "mandatory_non_claims",
    "primitive_names",
    "boundary_behaviors",
    "structural_outcomes",
    "aggregate_postures",
    "aggregate_posture_precedence",
    "simulation_classes"
  ],
  "properties": {
    "vocabulary_id": {
      "const": "fork_controlled_vocabulary_v0_1"
    },
    "schema_version": {
      "const": "0.1.1"
    },
    "status": {
      "const": "PROVISIONAL_CONTROLLED_VOCABULARY_HARDENED"
    },
    "mandatory_non_claims": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/non_claim"
      }
    },
    "primitive_names": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/primitive_name"
      }
    },
    "boundary_behaviors": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/boundary_behavior"
      }
    },
    "structural_outcomes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/structural_outcome"
      }
    },
    "aggregate_postures": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/aggregate_posture"
      }
    },
    "aggregate_posture_precedence": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/aggregate_posture_precedence_rule"
      }
    },
    "simulation_classes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/simulation_class"
      }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_claim": {
      "type": "string",
      "description": "Machine-readable non-claims. These values limit what Fork artifacts do not assert.",
      "enum": [
        "does_not_claim_truth",
        "does_not_claim_legal_sufficiency",
        "does_not_claim_admissibility",
        "does_not_claim_enforceability",
        "does_not_claim_liability_assignment",
        "does_not_claim_regulatory_compliance",
        "does_not_claim_evidentiary_admissibility",
        "does_not_claim_hearsay_exception_status",
        "does_not_claim_retention_compliance",
        "does_not_claim_legal_hold_compliance",
        "does_not_claim_ediscovery_preservation",
        "does_not_claim_legal_authentication",
        "does_not_claim_legal_attribution",
        "does_not_claim_legal_custody",
        "does_not_claim_legal_chain_of_custody",
        "does_not_claim_legal_provenance",
        "does_not_claim_legal_reliance",
        "does_not_claim_legal_representation",
        "does_not_claim_attorney_client_relationship",
        "does_not_claim_legal_advice",
        "does_not_claim_safe_harbor",
        "does_not_claim_compliance",
        "does_not_claim_safety",
        "does_not_claim_institutional_approval",
        "does_not_claim_production_readiness",
        "does_not_claim_medical_correctness",
        "does_not_claim_clinical_appropriateness",
        "does_not_claim_policy_sufficiency",
        "does_not_claim_authority",
        "does_not_claim_reference_truth",
        "does_not_claim_complete_provenance",
        "does_not_claim_actual_downstream_behavior",
        "does_not_claim_legal_claim_status",
        "does_not_claim_insurance_claim",
        "does_not_claim_patent_claim",
        "does_not_claim_cause_of_action",
        "does_not_claim_entitlement",
        "does_not_claim_intellectual_property_license"
      ]
    },
    "primitive_name": {
      "type": "string",
      "description": "Fork-native primitive names. Legally loaded primitives are intentionally excluded.",
      "enum": [
        "CLAIM",
        "NON_CLAIM",
        "SYSTEM_ASSERTION",
        "CLAIM_REFERENCED",
        "CLAIM_USED_AS_SUPPORT",
        "CLAIM_NON_USAGE_DECLARED",
        "ATTRIBUTION_REF",
        "AUTHORITY_REF",
        "AUTHORITY_REF_RESOLUTION_STATE",
        "EVIDENCE_REF",
        "EVIDENCE_REF_RESOLUTION_STATE",
        "RECORD_STRUCTURAL_STATE",
        "RECOMPUTATION_STATE",
        "RECORD_PERSISTENCE_STATE",
        "HANDOFF_EVENT",
        "PROVENANCE_REF",
        "BOUNDARY_BEHAVIOR",
        "STRUCTURAL_OUTCOME",
        "AGGREGATE_POSTURE"
      ]
    },
    "boundary_behavior": {
      "type": "string",
      "description": "Structural boundary behavior labels only.",
      "enum": [
        "BOUNDARY_PRESERVED",
        "BOUNDARY_NARROWED",
        "BOUNDARY_EXPANSION_DETECTED",
        "BOUNDARY_EXPANSION_RECORDED",
        "CLAIM_REJECTED",
        "POINTER_UNRESOLVED",
        "NON_CLAIM_DROPPED",
        "SCHEMA_BEHAVIOR_COLLAPSE_DETECTED",
        "AGGREGATE_COLLAPSE_DETECTED"
      ]
    },
    "structural_outcome": {
      "type": "string",
      "description": "Validator-observed structural outcomes. These are not legal, compliance, authority, safety, or truth outcomes.",
      "enum": [
        "BOUNDARY_MAPPING_PRESENT",
        "BOUNDARY_MAPPING_COMPLETE",
        "BOUNDARY_PRESERVED",
        "BOUNDARY_NARROWED",
        "BOUNDARY_EXPANSION_DETECTED",
        "BOUNDARY_EXPANSION_RECORDED",
        "CLAIM_REJECTED",
        "NON_CLAIM_DROPPED",
        "POINTER_UNRESOLVED",
        "AUTHORITY_REF_MISSING",
        "AUTHORITY_REF_RECORDED_RESOLUTION_NOT_PERFORMED",
        "AUTHORITY_REF_RESOLUTION_ATTEMPTED_UNREACHABLE",
        "AUTHORITY_REF_STRUCTURALLY_REACHABLE",
        "AUTHORITY_REF_STRUCTURAL_MISMATCH_DETECTED",
        "EVIDENCE_REF_MISSING",
        "EVIDENCE_REF_RECORDED_RESOLUTION_NOT_PERFORMED",
        "EVIDENCE_REF_RESOLUTION_ATTEMPTED_UNREACHABLE",
        "EVIDENCE_REF_STRUCTURALLY_REACHABLE",
        "EVIDENCE_REF_STRUCTURAL_MISMATCH_DETECTED",
        "SCHEMA_BEHAVIOR_COLLAPSE_DETECTED",
        "AGGREGATE_COLLAPSE_DETECTED",
        "DECLARED_BEHAVIOR_MISMATCH_DETECTED",
        "MAPPING_INCOMPLETE",
        "MAPPED_WITH_UNRESOLVED_REFERENCES",
        "STRUCTURAL_CONFORMANCE_CONFIRMED"
      ]
    },
    "aggregate_posture": {
      "type": "string",
      "description": "Structural aggregate posture labels. These are not compliance, approval, safety, sufficiency, or truth labels.",
      "enum": [
        "NO_MAPPING_PRESENT",
        "INCOMPLETE_MAPPING",
        "MAPPED_WITH_UNRESOLVED_REFERENCES",
        "EXPANSION_MAPPING_PRESENT",
        "BOUNDARY_MAPPING_COMPLETE",
        "STRUCTURAL_CONFORMANCE_CONFIRMED",
        "AGGREGATE_COLLAPSE_DETECTED"
      ]
    },
    "aggregate_posture_precedence_rule": {
      "type": "string",
      "description": "Machine-readable precedence labels for aggregate posture computation. Collapse, incomplete, and unresolved states take precedence over positive structural summaries.",
      "enum": [
        "NO_MAPPING_PRESENT_PRECEDENCE",
        "AGGREGATE_COLLAPSE_PRECEDENCE",
        "INCOMPLETE_MAPPING_PRECEDENCE",
        "UNRESOLVED_REFERENCES_PRECEDENCE",
        "EXPANSION_MAPPING_PRESENT_PRECEDENCE",
        "BOUNDARY_MAPPING_COMPLETE_PRECEDENCE",
        "STRUCTURAL_CONFORMANCE_CONFIRMED_PRECEDENCE"
      ]
    },
    "authority_ref_resolution_state": {
      "type": "string",
      "description": "Structural authority-reference states. Structurally reachable does not mean legally valid authority.",
      "enum": [
        "AUTHORITY_REF_MISSING",
        "AUTHORITY_REF_RECORDED_RESOLUTION_NOT_PERFORMED",
        "AUTHORITY_REF_RESOLUTION_ATTEMPTED_UNREACHABLE",
        "AUTHORITY_REF_STRUCTURALLY_REACHABLE",
        "AUTHORITY_REF_STRUCTURAL_MISMATCH_DETECTED"
      ]
    },
    "evidence_ref_resolution_state": {
      "type": "string",
      "description": "Structural evidence-reference states. Structurally reachable does not mean evidentiary sufficiency.",
      "enum": [
        "EVIDENCE_REF_MISSING",
        "EVIDENCE_REF_RECORDED_RESOLUTION_NOT_PERFORMED",
        "EVIDENCE_REF_RESOLUTION_ATTEMPTED_UNREACHABLE",
        "EVIDENCE_REF_STRUCTURALLY_REACHABLE",
        "EVIDENCE_REF_STRUCTURAL_MISMATCH_DETECTED"
      ]
    },
    "record_structural_state": {
      "type": "string",
      "description": "Checker-action states for record structure. These do not claim truth or legal authentication.",
      "enum": [
        "STRUCTURAL_CHECK_PASSED",
        "STRUCTURAL_CHECK_FAILED",
        "STRUCTURAL_CHECK_NOT_PERFORMED",
        "HASH_MISMATCH_DETECTED",
        "SCHEMA_MISMATCH_DETECTED"
      ]
    },
    "recomputation_state": {
      "type": "string",
      "description": "Recomputation and structural comparison states.",
      "enum": [
        "RECOMPUTATION_NOT_PERFORMED",
        "RECOMPUTED_MATCH",
        "RECOMPUTED_MISMATCH",
        "RECOMPUTATION_INPUT_MISSING",
        "RECOMPUTATION_BLOCKED_BY_UNRESOLVED_POINTER"
      ]
    },
    "record_persistence_state": {
      "type": "string",
      "description": "Structural record presence or persistence-declaration states. These do not claim legal retention compliance, legal hold status, regulatory record-keeping compliance, or admissibility as a retained record.",
      "enum": [
        "RECORD_PRESENT_AT_STRUCTURAL_INSPECTION",
        "RECORD_ABSENT_AT_STRUCTURAL_INSPECTION",
        "RECORD_POINTER_SUPPLIED_RESOLUTION_NOT_PERFORMED",
        "RECORD_POINTER_UNRESOLVED",
        "RECORD_PERSISTENCE_DECLARATION_RECORDED"
      ]
    },
    "claim_relationship_state": {
      "type": "string",
      "description": "Distinguishes reference, support use, and declared non-usage without importing legal reliance.",
      "enum": [
        "CLAIM_REFERENCED",
        "CLAIM_USED_AS_SUPPORT",
        "CLAIM_NON_USAGE_DECLARED",
        "CLAIM_RELATIONSHIP_NOT_DECLARED"
      ]
    },
    "assertion_source": {
      "type": "string",
      "description": "Source category for a system assertion. This does not assign legal attribution or responsibility.",
      "enum": [
        "AI_GENERATED",
        "HUMAN_GENERATED",
        "SYSTEM_GENERATED",
        "HYBRID_GENERATED",
        "SOURCE_NOT_DECLARED"
      ]
    },
    "reference_kind": {
      "type": "string",
      "enum": [
        "INTERNAL_RECEIPT_REF",
        "EXTERNAL_RECORD_POINTER",
        "POLICY_POINTER",
        "HUMAN_REVIEW_POINTER",
        "SYSTEM_ASSERTION_POINTER",
        "UNKNOWN_POINTER"
      ]
    },
    "simulation_class": {
      "type": "string",
      "description": "Synthetic simulation classes for claim-inheritance behavior.",
      "enum": [
        "SIM_A_BOUNDARY_PRESERVED",
        "SIM_B_BOUNDARY_NARROWED",
        "SIM_C_NON_CLAIM_DROPPED",
        "SIM_D_EXPANSION_WITHOUT_AUTHORITY",
        "SIM_E_EXPANSION_WITH_RECORDED_UNRESOLVED_AUTHORITY",
        "SIM_F_POINTER_UNRESOLVED",
        "SIM_G1_SELF_CHARACTERIZATION_PRESERVED_NON_CLAIM_DROPPED",
        "SIM_G2_SELF_CHARACTERIZATION_PRESERVED_EXPANSION_OBSERVED",
        "SIM_G3_SELF_CHARACTERIZATION_NARROWED_EXPANSION_OBSERVED",
        "SIM_H_CASCADING_INHERITANCE",
        "SIM_I_BOUNDARY_REJECTION",
        "SIM_J_SCHEMA_BEHAVIOR_COLLAPSE",
        "SIM_K_MULTI_BEHAVIOR_HANDOFF",
        "SIM_L_STRUCTURALLY_VALID_MISLEADING_SELF_REPORT",
        "SIM_M_AGGREGATE_COLLAPSE"
      ]
    },
    "vocabulary_non_claims_object": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "non_claims"
      ],
      "properties": {
        "non_claims": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/non_claim"
          }
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "description": "A bounded statement asserted by a system, actor, model, workflow, or artifact about a subject. This does not mean a legal claim, insurance claim, patent claim, cause of action, demand, entitlement, or assertion of legal right.",
      "required": [
        "claim_id",
        "claim_text",
        "claim_subject",
        "non_claims"
      ],
      "properties": {
        "claim_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "claim_text": {
          "$ref": "#/$defs/non_empty_string"
        },
        "claim_subject": {
          "$ref": "#/$defs/non_empty_string"
        },
        "non_claims": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/non_claim"
          }
        }
      }
    },
    "system_assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assertion_id",
        "assertion_source",
        "assertion_text",
        "non_claims"
      ],
      "properties": {
        "assertion_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "assertion_source": {
          "$ref": "#/$defs/assertion_source"
        },
        "assertion_text": {
          "$ref": "#/$defs/non_empty_string"
        },
        "non_claims": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/non_claim"
          }
        }
      }
    },
    "handoff_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "handoff_event_id",
        "sender",
        "receiver",
        "timestamp",
        "artifact_ref",
        "non_claims"
      ],
      "properties": {
        "handoff_event_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "sender": {
          "$ref": "#/$defs/non_empty_string"
        },
        "receiver": {
          "$ref": "#/$defs/non_empty_string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "artifact_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "record_structural_state": {
          "$ref": "#/$defs/record_structural_state"
        },
        "recomputation_state": {
          "$ref": "#/$defs/recomputation_state"
        },
        "non_claims": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/non_claim"
          }
        }
      }
    },
    "authority_ref_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_ref",
        "authority_ref_kind",
        "authority_ref_resolution_attempted",
        "authority_ref_resolution_state"
      ],
      "properties": {
        "authority_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "authority_ref_kind": {
          "$ref": "#/$defs/reference_kind"
        },
        "authority_ref_resolution_attempted": {
          "type": "boolean"
        },
        "authority_ref_resolution_state": {
          "$ref": "#/$defs/authority_ref_resolution_state"
        }
      }
    },
    "evidence_ref_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_ref",
        "evidence_ref_kind",
        "evidence_ref_resolution_attempted",
        "evidence_ref_resolution_state"
      ],
      "properties": {
        "evidence_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_ref_kind": {
          "$ref": "#/$defs/reference_kind"
        },
        "evidence_ref_resolution_attempted": {
          "type": "boolean"
        },
        "evidence_ref_resolution_state": {
          "$ref": "#/$defs/evidence_ref_resolution_state"
        }
      }
    },
    "boundary_behavior_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_ref",
        "claim_relationship_state",
        "consumer_declared_boundary_behavior",
        "validator_observed_boundary_behavior",
        "preserved_non_claims",
        "dropped_non_claims",
        "structural_outcomes"
      ],
      "properties": {
        "claim_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "claim_relationship_state": {
          "$ref": "#/$defs/claim_relationship_state"
        },
        "consumer_declared_boundary_behavior": {
          "$ref": "#/$defs/boundary_behavior"
        },
        "validator_observed_boundary_behavior": {
          "$ref": "#/$defs/boundary_behavior"
        },
        "preserved_non_claims": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/non_claim"
          }
        },
        "dropped_non_claims": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/non_claim"
          }
        },
        "authority_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/authority_ref_record"
          }
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_ref_record"
          }
        },
        "structural_outcomes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/structural_outcome"
          }
        }
      }
    },
    "controlled_vocabulary_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vocabulary_id",
        "schema_version",
        "status",
        "mandatory_non_claims",
        "primitive_names",
        "boundary_behaviors",
        "structural_outcomes",
        "aggregate_postures",
        "aggregate_posture_precedence",
        "simulation_classes"
      ],
      "properties": {
        "vocabulary_id": {
          "const": "fork_controlled_vocabulary_v0_1"
        },
        "schema_version": {
          "const": "0.1.1"
        },
        "status": {
          "const": "PROVISIONAL_CONTROLLED_VOCABULARY_HARDENED"
        },
        "mandatory_non_claims": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/non_claim"
          }
        },
        "primitive_names": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/primitive_name"
          }
        },
        "boundary_behaviors": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/boundary_behavior"
          }
        },
        "structural_outcomes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/structural_outcome"
          }
        },
        "aggregate_postures": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/aggregate_posture"
          }
        },
        "aggregate_posture_precedence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/aggregate_posture_precedence_rule"
          }
        },
        "simulation_classes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/simulation_class"
          }
        }
      }
    }
  },
  "examples": [
    {
      "vocabulary_id": "fork_controlled_vocabulary_v0_1",
      "schema_version": "0.1.1",
      "status": "PROVISIONAL_CONTROLLED_VOCABULARY_HARDENED",
      "mandatory_non_claims": [
        "does_not_claim_legal_advice",
        "does_not_claim_legal_sufficiency",
        "does_not_claim_admissibility",
        "does_not_claim_legal_reliance",
        "does_not_claim_legal_representation",
        "does_not_claim_legal_chain_of_custody",
        "does_not_claim_retention_compliance",
        "does_not_claim_intellectual_property_license",
        "does_not_claim_truth"
      ],
      "primitive_names": [
        "CLAIM",
        "NON_CLAIM",
        "SYSTEM_ASSERTION",
        "CLAIM_REFERENCED",
        "CLAIM_USED_AS_SUPPORT",
        "CLAIM_NON_USAGE_DECLARED",
        "HANDOFF_EVENT",
        "PROVENANCE_REF",
        "RECORD_STRUCTURAL_STATE",
        "RECOMPUTATION_STATE",
        "RECORD_PERSISTENCE_STATE",
        "BOUNDARY_BEHAVIOR",
        "STRUCTURAL_OUTCOME",
        "AGGREGATE_POSTURE"
      ],
      "boundary_behaviors": [
        "BOUNDARY_PRESERVED",
        "BOUNDARY_EXPANSION_DETECTED",
        "POINTER_UNRESOLVED",
        "AGGREGATE_COLLAPSE_DETECTED"
      ],
      "structural_outcomes": [
        "BOUNDARY_MAPPING_PRESENT",
        "BOUNDARY_EXPANSION_DETECTED",
        "AUTHORITY_REF_MISSING",
        "MAPPING_INCOMPLETE",
        "AGGREGATE_COLLAPSE_DETECTED"
      ],
      "aggregate_postures": [
        "INCOMPLETE_MAPPING",
        "AGGREGATE_COLLAPSE_DETECTED"
      ],
      "aggregate_posture_precedence": [
        "NO_MAPPING_PRESENT_PRECEDENCE",
        "AGGREGATE_COLLAPSE_PRECEDENCE",
        "INCOMPLETE_MAPPING_PRECEDENCE"
      ],
      "simulation_classes": [
        "SIM_D_EXPANSION_WITHOUT_AUTHORITY",
        "SIM_H_CASCADING_INHERITANCE",
        "SIM_M_AGGREGATE_COLLAPSE"
      ]
    }
  ]
}
