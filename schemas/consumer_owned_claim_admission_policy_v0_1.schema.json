{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.org/schemas/consumer_owned_claim_admission_policy_v0_1.schema.json",
  "title": "Fork Consumer-Owned Claim Admission Policy v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policy_id",
    "schema_version",
    "status",
    "consumer_owner",
    "failure_class_addressed",
    "trusted_base_contract",
    "activation_state",
    "protected_control_paths",
    "candidate_tree_requirements",
    "workflow_requirements",
    "provenance_bound_workflow_successors",
    "admission_semantics",
    "repository_settings_effect",
    "historical_rewrite_authority",
    "experiment_effect",
    "non_claims"
  ],
  "properties": {
    "policy_id": {"const": "FORK_CONSUMER_OWNED_CLAIM_ADMISSION_POLICY_v0_1"},
    "schema_version": {"const": "0.1"},
    "status": {"enum": ["PROPOSED_FOR_ADMISSION", "ADMITTED"]},
    "consumer_owner": {"type": "string", "minLength": 1},
    "failure_class_addressed": {"const": "CCF-001_AI_CHANGE_READINESS_PROMOTION"},
    "trusted_base_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow_path", "trigger", "checker_path", "dependency_lock", "candidate_handling", "candidate_checkout", "candidate_code_execution", "secret_use", "token_permissions", "runner_class"],
      "properties": {
        "workflow_path": {"const": ".github/workflows/consumer-owned-claim-admission.yml"},
        "trigger": {"const": "PULL_REQUEST_TARGET"},
        "checker_path": {"const": "tools/check_claim_admission_gate_v0_1.py"},
        "dependency_lock": {"const": "requirements-claim-admission.lock.txt"},
        "candidate_handling": {"const": "READ_AS_GIT_OBJECT_DATA_ONLY"},
        "candidate_checkout": {"const": "PROHIBITED"},
        "candidate_code_execution": {"const": "PROHIBITED"},
        "secret_use": {"const": "PROHIBITED"},
        "token_permissions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["contents"],
          "properties": {"contents": {"const": "read"}}
        },
        "runner_class": {"const": "GITHUB_HOSTED_EPHEMERAL"}
      }
    },
    "activation_state": {"const": "IMPLEMENTED_DORMANT_UNTIL_PRESENT_ON_DEFAULT_BRANCH"},
    "protected_control_paths": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "candidate_tree_requirements": {"type": "object", "minProperties": 1},
    "workflow_requirements": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "patternProperties": {"^[a-z][a-z0-9_]*$": {"type": "boolean"}}
    },
    "provenance_bound_workflow_successors": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "successor_sha256", "original_sha256", "archive_path", "provenance_path", "classification", "disposition"],
        "properties": {
          "path": {"type": "string", "pattern": "^\\.github/workflows/.+\\.ya?ml$"},
          "successor_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "original_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "archive_path": {"type": "string", "minLength": 1},
          "provenance_path": {"type": "string", "minLength": 1},
          "classification": {"const": "PROVENANCE_BOUND_HARDENED_EXPERIMENT_INSTRUMENTATION_SUCCESSOR"},
          "disposition": {"const": "FULL_HARDENING_REQUIRED_AND_EXECUTION_SEPARATELY_GATED"}
        }
      }
    },
    "admission_semantics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["structural_pass_effect", "structural_failure_effect", "repository_standing_effect", "human_and_institutional_review_required", "branch_rule_enforcement_required"],
      "properties": {
        "structural_pass_effect": {"const": "REVIEW_ELIGIBLE_NOT_ADMITTED"},
        "structural_failure_effect": {"const": "NOT_REVIEW_ELIGIBLE"},
        "repository_standing_effect": {"const": "NONE"},
        "human_and_institutional_review_required": {"const": true},
        "branch_rule_enforcement_required": {"const": true}
      }
    },
    "repository_settings_effect": {"const": "NONE"},
    "historical_rewrite_authority": {"const": "NONE"},
    "experiment_effect": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "patternProperties": {"^[a-z][a-z0-9_]*$": {"const": false}}
    },
    "non_claims": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  }
}
