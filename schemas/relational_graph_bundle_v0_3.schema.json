{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recomputableevidence.example/schemas/relational_graph_bundle_v0_3.schema.json",
  "title": "Relational Graph Bundle v0.3",
  "description": "A bounded, stateless verification payload containing CBC and CCE records for local relational graph inspection.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_type",
    "graph_bundle_version",
    "graph_id",
    "created_at_utc",
    "verification_mode",
    "verification_scope",
    "cbc_records",
    "cce_records",
    "bundle_non_claims"
  ],
  "properties": {
    "record_type": {
      "const": "RELATIONAL_GRAPH_BUNDLE"
    },
    "graph_bundle_version": {
      "const": "RGV_BUNDLE_v0_3"
    },
    "graph_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "verification_mode": {
      "const": "STATELESS_BUNDLE_ONLY"
    },
    "verification_scope": {
      "const": "RELATIONAL_GRAPH_STRUCTURE_ONLY"
    },
    "cbc_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/wrapped_record"
      }
    },
    "cce_records": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/wrapped_record"
      }
    },
    "bundle_non_claims": {
      "type": "array",
      "minItems": 5,
      "items": {
        "$ref": "#/$defs/non_claim"
      }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "wrapped_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "record"
      ],
      "properties": {
        "artifact_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "record": {
          "type": "object"
        }
      }
    },
    "non_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "non_claim_id",
        "statement"
      ],
      "properties": {
        "non_claim_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "statement": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
