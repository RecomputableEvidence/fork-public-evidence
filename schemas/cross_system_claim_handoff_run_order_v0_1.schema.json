{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recomputableevidence.example/schemas/cross_system_claim_handoff_run_order_v0_1.schema.json",
  "title": "Cross-System Claim Handoff Fixed Run Order v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "experiment_id",
    "order_id",
    "generation_method",
    "fixed_salt",
    "pair_block_count",
    "run_unit_count",
    "units",
    "non_claims"
  ],
  "properties": {
    "artifact_type": {
      "const": "csh_fixed_run_order"
    },
    "schema_version": {
      "const": "v0.1"
    },
    "experiment_id": {
      "const": "cross_system_claim_handoff_v0_1"
    },
    "order_id": {
      "const": "CSH_RUN_ORDER_v0_1"
    },
    "generation_method": {
      "type": "string",
      "minLength": 1
    },
    "fixed_salt": {
      "const": "CSH_V0_1_PAIR_BLOCK_ORDER_SHA256_2026_07_11"
    },
    "pair_block_count": {
      "const": 54
    },
    "run_unit_count": {
      "const": 108
    },
    "units": {
      "type": "array",
      "minItems": 108,
      "maxItems": 108,
      "items": {
        "$ref": "#/$defs/unit"
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "unit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ordinal",
        "planned_run_id",
        "pair_block_ordinal",
        "pairing_key",
        "scenario_id",
        "condition",
        "receiver_class_id",
        "replicate_id",
        "system_instruction_path",
        "prompt_path",
        "source_artifact_path",
        "handoff_artifact_path",
        "handoff_artifact_present",
        "receiver_entrypoint"
      ],
      "properties": {
        "ordinal": {
          "type": "integer",
          "minimum": 1,
          "maximum": 108
        },
        "planned_run_id": {
          "type": "string",
          "pattern": "^CSH-RUN-[0-9]{3}$"
        },
        "pair_block_ordinal": {
          "type": "integer",
          "minimum": 1,
          "maximum": 54
        },
        "pairing_key": {
          "type": "string",
          "minLength": 1
        },
        "scenario_id": {
          "type": "string"
        },
        "condition": {
          "enum": [
            "control_h0",
            "instrumented_h1"
          ]
        },
        "receiver_class_id": {
          "enum": [
            "llm_receiver_a",
            "llm_receiver_b",
            "deterministic_receiver"
          ]
        },
        "replicate_id": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "system_instruction_path": {
          "type": "string",
          "minLength": 1
        },
        "prompt_path": {
          "type": "string",
          "minLength": 1
        },
        "source_artifact_path": {
          "type": "string",
          "minLength": 1
        },
        "handoff_artifact_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "handoff_artifact_present": {
          "type": "boolean"
        },
        "receiver_entrypoint": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "condition": {
            "const": "control_h0"
          }
        }
      },
      "then": {}
    }
  ]
}
