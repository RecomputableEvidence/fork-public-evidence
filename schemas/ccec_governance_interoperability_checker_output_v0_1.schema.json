{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.org/schemas/ccec_governance_interoperability_checker_output_v0_1.schema.json",
  "title": "CCEC Governance Interoperability Checker Output Contract v0.1.1 Runtime Use Hardened",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "checker",
    "input",
    "result",
    "errors",
    "warnings",
    "scope",
    "limitations",
    "do_not_map_to",
    "non_claims"
  ],
  "properties": {
    "checker": {
      "$ref": "#/definitions/checker"
    },
    "input": {
      "$ref": "#/definitions/input"
    },
    "result": {
      "$ref": "#/definitions/result"
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/finding"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/finding"
      }
    },
    "scope": {
      "$ref": "#/definitions/scope"
    },
    "limitations": {
      "$ref": "#/definitions/limitations"
    },
    "do_not_map_to": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 42,
      "items": {
        "type": "string",
        "enum": [
          "APPROVAL",
          "APPROVED",
          "TRUTH",
          "TRUE",
          "VERIFIED",
          "SAFETY",
          "SAFE",
          "COMPLIANCE",
          "COMPLIANT",
          "CERTIFIED",
          "LEGAL",
          "LEGAL_SUFFICIENCY",
          "AUTHORITY",
          "AUTHORIZED",
          "INSTITUTIONAL_AUTHORIZATION",
          "POLICY",
          "POLICY_SATISFACTION",
          "RISK",
          "RISK_ACCEPTANCE",
          "VALID",
          "VALIDATED",
          "AUTHORITY_TRANSFER",
          "CLAIM_EXPANSION_BY_MAPPING",
          "AUTOMATED_CONTROL_DECISION",
          "CONTROL_STATUS",
          "CONTROL_EFFECTIVENESS_STATUS",
          "CONTROL_SATISFIED",
          "AUTOMATED_CONTROL_SATISFIED",
          "ASSURANCE_LEVEL",
          "CONFIDENCE_LEVEL",
          "RESIDUAL_RISK_STATUS",
          "ISSUE_CLOSED_STATUS",
          "SIGN_OFF_STATUS",
          "GO_LIVE_AUTHORIZATION",
          "DEPLOYMENT_APPROVED",
          "EVIDENCE_SUFFICIENCY",
          "AUDIT_SUFFICIENCY",
          "REASONABLE_RELIANCE",
          "STANDARD_OF_CARE",
          "DELEGATED_AUTHORITY",
          "PERPETUAL_RELIANCE",
          "SOLE_EVIDENCE"
        ]
      }
    },
    "non_claims": {
      "$ref": "#/definitions/non_claims"
    }
  },
  "definitions": {
    "checker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "const": "check_ccec_governance_interoperability"
        },
        "version": {
          "const": "0.1.1"
        }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string"
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ok",
        "result_kind"
      ],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "result_kind": {
          "type": "string",
          "enum": [
            "STRUCTURAL_PASS",
            "SCHEMA_VALIDATION_FAILED",
            "CONTRACT_VALIDATION_FAILED",
            "INPUT_ERROR",
            "OUTPUT_CONTRACT_VIOLATION"
          ]
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checker_scope",
        "validates",
        "does_not_validate"
      ],
      "properties": {
        "checker_scope": {
          "const": "structural_ccec_governance_interoperability_validation_only"
        },
        "validates": {
          "type": "array",
          "uniqueItems": true,
          "minItems": 12,
          "items": {
            "type": "string",
            "enum": [
              "json_parseability",
              "ccec_governance_interoperability_schema_conformance",
              "permitted_mapping_consistency",
              "prohibited_mapping_completeness",
              "expanded_do_not_map_to_completeness",
              "runtime_use_constraints",
              "rendering_constraints",
              "aggregation_constraints",
              "forbidden_oracle_target_field_absence",
              "authority_inheritance_prohibition",
              "unresolved_gap_preservation",
              "checker_output_contract_conformance"
            ]
          }
        },
        "does_not_validate": {
          "type": "array",
          "uniqueItems": true,
          "minItems": 14,
          "items": {
            "type": "string",
            "enum": [
              "truth_of_source_ccec",
              "correctness_of_external_governance_decision",
              "compliance_of_external_system",
              "safety_of_external_system",
              "legal_sufficiency_of_external_decision",
              "institutional_authority_of_external_owner",
              "policy_satisfaction",
              "risk_acceptance",
              "control_satisfaction",
              "issue_closure",
              "deployment_authorization",
              "evidence_sufficiency",
              "reasonable_reliance",
              "aggregation_posture"
            ]
          }
        }
      }
    },
    "limitations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "safe_to_automate",
        "automation_interpretation_required",
        "bounded_reference_only",
        "synthetic_structural_checker_only",
        "does_not_validate_approval",
        "does_not_validate_truth",
        "does_not_validate_safety",
        "does_not_validate_compliance",
        "does_not_validate_legal_sufficiency",
        "does_not_validate_institutional_authorization",
        "does_not_validate_policy_satisfaction",
        "does_not_validate_risk_acceptance",
        "does_not_validate_control_satisfaction",
        "does_not_validate_issue_closure",
        "does_not_validate_deployment_authorization",
        "does_not_validate_evidence_sufficiency",
        "does_not_validate_reasonable_reliance",
        "does_not_validate_aggregation_posture",
        "does_not_transfer_authority",
        "not_runtime_control",
        "not_policy_engine",
        "not_compliance_oracle"
      ],
      "properties": {
        "safe_to_automate": {
          "const": false
        },
        "automation_interpretation_required": {
          "const": true
        },
        "bounded_reference_only": {
          "const": true
        },
        "synthetic_structural_checker_only": {
          "const": true
        },
        "does_not_validate_approval": {
          "const": true
        },
        "does_not_validate_truth": {
          "const": true
        },
        "does_not_validate_safety": {
          "const": true
        },
        "does_not_validate_compliance": {
          "const": true
        },
        "does_not_validate_legal_sufficiency": {
          "const": true
        },
        "does_not_validate_institutional_authorization": {
          "const": true
        },
        "does_not_validate_policy_satisfaction": {
          "const": true
        },
        "does_not_validate_risk_acceptance": {
          "const": true
        },
        "does_not_validate_control_satisfaction": {
          "const": true
        },
        "does_not_validate_issue_closure": {
          "const": true
        },
        "does_not_validate_deployment_authorization": {
          "const": true
        },
        "does_not_validate_evidence_sufficiency": {
          "const": true
        },
        "does_not_validate_reasonable_reliance": {
          "const": true
        },
        "does_not_validate_aggregation_posture": {
          "const": true
        },
        "does_not_transfer_authority": {
          "const": true
        },
        "not_runtime_control": {
          "const": true
        },
        "not_policy_engine": {
          "const": true
        },
        "not_compliance_oracle": {
          "const": true
        }
      }
    },
    "non_claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "does_not_create_approval_status",
        "does_not_create_compliance_status",
        "does_not_create_safety_status",
        "does_not_create_truth_status",
        "does_not_create_legal_sufficiency_status",
        "does_not_transfer_authority",
        "does_not_close_unresolved_gaps",
        "does_not_accept_risk"
      ],
      "properties": {
        "does_not_create_approval_status": {
          "const": true
        },
        "does_not_create_compliance_status": {
          "const": true
        },
        "does_not_create_safety_status": {
          "const": true
        },
        "does_not_create_truth_status": {
          "const": true
        },
        "does_not_create_legal_sufficiency_status": {
          "const": true
        },
        "does_not_transfer_authority": {
          "const": true
        },
        "does_not_close_unresolved_gaps": {
          "const": true
        },
        "does_not_accept_risk": {
          "const": true
        }
      }
    }
  }
}
