{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recomputableevidence.example/schemas/cross_system_claim_handoff_scenario_v0_1.schema.json",
  "title": "Cross-System Claim Handoff Scenario v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scenario_id",
    "schema_version",
    "pressure_class",
    "source_claims",
    "source_non_claims",
    "expected_relationship",
    "permitted_transformations",
    "unresolved_references",
    "prohibited_outcomes"
  ],
  "properties": {
    "scenario_id": {
      "type": "string",
      "pattern": "^SIM_[A-Z]_"
    },
    "schema_version": {
      "const": "v0.1"
    },
    "pressure_class": {
      "type": "string"
    },
    "source_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_id",
          "text"
        ],
        "properties": {
          "claim_id": {
            "type": "string"
          },
          "text": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "source_non_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "expected_relationship": {
      "enum": [
        "PRESERVED",
        "NARROWED",
        "EXPANDED",
        "UNRESOLVED",
        "MIXED"
      ]
    },
    "permitted_transformations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unresolved_references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prohibited_outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
