{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fork.local/schemas/claim_profile_v0_1.schema.json",
  "title": "Fork Claim Profile v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_id",
    "profile_version",
    "claim_type",
    "claim_scope",
    "claim_statement",
    "allowed_inferences",
    "forbidden_inferences",
    "not_checked",
    "non_claims",
    "binding_rules"
  ],
  "properties": {
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "profile_version": {
      "type": "string",
      "const": "0.1"
    },
    "claim_type": {
      "type": "string",
      "enum": [
        "OBSERVED_WORKFLOW_EVENT_INTEGRITY_ONLY"
      ]
    },
    "claim_scope": {
      "type": "string",
      "minLength": 1
    },
    "claim_statement": {
      "type": "string",
      "minLength": 1
    },
    "allowed_inferences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_inferences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "not_checked": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "binding_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "existing_claim_boundary_policy",
        "emitted_artifact_must_pass_artifact_checker"
      ],
      "properties": {
        "existing_claim_boundary_policy": {
          "type": "string",
          "const": "FAIL_UNLESS_REPLACE_FLAG"
        },
        "emitted_artifact_must_pass_artifact_checker": {
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}