{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fork.local/schemas/claim_boundary_v0_1.schema.json",
  "title": "Fork Claim Boundary v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "claim_type",
    "claim_statement",
    "allowed_inferences",
    "forbidden_inferences",
    "not_checked",
    "non_claims"
  ],
  "properties": {
    "claim_type": {
      "type": "string",
      "enum": [
        "OBSERVED_WORKFLOW_EVENT_INTEGRITY_ONLY"
      ]
    },
    "claim_statement": {
      "type": "string",
      "minLength": 1
    },
    "allowed_inferences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_inferences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "not_checked": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}