{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recomputable-evidence.example/schemas/controlled_pilot_readiness_gate_v0_1.schema.json",
  "title": "Fork Controlled Pilot Package Index / Readiness Gate v0.1",
  "type": "object",
  "oneOf": [
    {
      "$ref": "#/$defs/package_index"
    },
    {
      "$ref": "#/$defs/readiness_receipt"
    }
  ],
  "$defs": {
    "package_index": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_type",
        "schema_version",
        "package_id",
        "package_name",
        "package_scope",
        "package_components",
        "readiness_non_claims"
      ],
      "properties": {
        "record_type": {
          "const": "FORK_CONTROLLED_PILOT_PACKAGE_INDEX"
        },
        "schema_version": {
          "const": "0.1"
        },
        "package_id": {
          "type": "string",
          "minLength": 1
        },
        "package_name": {
          "type": "string",
          "minLength": 1
        },
        "package_scope": {
          "type": "string",
          "minLength": 1
        },
        "package_components": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/package_component"
          }
        },
        "readiness_non_claims": {
          "$ref": "#/$defs/readiness_non_claim_set"
        }
      }
    },
    "package_component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component_id",
        "component_type",
        "path",
        "required"
      ],
      "properties": {
        "component_id": {
          "type": "string",
          "minLength": 1
        },
        "component_type": {
          "enum": [
            "DOCUMENT",
            "JSON_SCHEMA",
            "CHECKER",
            "TEMPLATE_DIRECTORY",
            "FIXTURE_DIRECTORY",
            "TEST_FILE"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "readiness_receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_type",
        "schema_version",
        "package_id",
        "checked_index_path",
        "gate_result",
        "component_count_required",
        "component_count_present",
        "component_count_missing",
        "missing_components",
        "component_checks",
        "integration_checks",
        "errors",
        "readiness_non_claims",
        "live_ingestion_authorization"
      ],
      "properties": {
        "record_type": {
          "const": "FORK_CONTROLLED_PILOT_READINESS_RECEIPT"
        },
        "schema_version": {
          "const": "0.1"
        },
        "package_id": {
          "type": "string",
          "minLength": 1
        },
        "checked_index_path": {
          "type": "string",
          "minLength": 1
        },
        "gate_result": {
          "enum": [
            "CONTROLLED_PILOT_PACKAGE_STRUCTURALLY_READY",
            "CONTROLLED_PILOT_PACKAGE_STRUCTURALLY_INCOMPLETE"
          ]
        },
        "component_count_required": {
          "type": "integer",
          "minimum": 0
        },
        "component_count_present": {
          "type": "integer",
          "minimum": 0
        },
        "component_count_missing": {
          "type": "integer",
          "minimum": 0
        },
        "missing_components": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/component_finding"
          }
        },
        "component_checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/component_check"
          }
        },
        "integration_checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/integration_check"
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "readiness_non_claims": {
          "$ref": "#/$defs/readiness_non_claim_set"
        },
        "live_ingestion_authorization": {
          "$ref": "#/$defs/live_ingestion_authorization_boundary"
        }
      }
    },
    "component_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component_id",
        "path",
        "code"
      ],
      "properties": {
        "component_id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "code": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "component_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component_id",
        "component_type",
        "path",
        "status"
      ],
      "properties": {
        "component_id": {
          "type": "string",
          "minLength": 1
        },
        "component_type": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "PRESENT",
            "MISSING",
            "INVALID"
          ]
        }
      }
    },
    "integration_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "status",
        "details"
      ],
      "properties": {
        "check_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "PASS",
            "FAIL"
          ]
        },
        "details": {
          "type": "object"
        }
      }
    },
    "readiness_non_claim_set": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "uniqueItems": true,
      "items": {
        "enum": [
          "READINESS_GATE_DOES_NOT_AUTHORIZE_LIVE_INGESTION",
          "READINESS_GATE_DOES_NOT_CERTIFY_PRODUCTION_READINESS",
          "READINESS_GATE_DOES_NOT_CERTIFY_SOURCE_TRUTH",
          "READINESS_GATE_DOES_NOT_CERTIFY_COMPLETENESS",
          "READINESS_GATE_DOES_NOT_CERTIFY_LEGAL_ADMISSIBILITY",
          "READINESS_GATE_DOES_NOT_CERTIFY_LAWFULNESS",
          "READINESS_GATE_DOES_NOT_CERTIFY_REGULATORY_COMPLIANCE",
          "READINESS_GATE_DOES_NOT_CERTIFY_HIPAA_COMPLIANCE",
          "READINESS_GATE_DOES_NOT_CERTIFY_MEDICAL_CORRECTNESS",
          "READINESS_GATE_DOES_NOT_CERTIFY_CLINICAL_APPROPRIATENESS",
          "READINESS_GATE_DOES_NOT_CERTIFY_UTILIZATION_MANAGEMENT_SUFFICIENCY",
          "READINESS_GATE_DOES_NOT_REPLACE_INSTITUTIONAL_APPROVAL"
        ]
      },
      "allOf": [
        {
          "contains": {
            "const": "READINESS_GATE_DOES_NOT_AUTHORIZE_LIVE_INGESTION"
          }
        },
        {
          "contains": {
            "const": "READINESS_GATE_DOES_NOT_CERTIFY_PRODUCTION_READINESS"
          }
        },
        {
          "contains": {
            "const": "READINESS_GATE_DOES_NOT_CERTIFY_SOURCE_TRUTH"
          }
        },
        {
          "contains": {
            "const": "READINESS_GATE_DOES_NOT_CERTIFY_COMPLETENESS"
          }
        },
        {
          "contains": {
            "const": "READINESS_GATE_DOES_NOT_CERTIFY_LEGAL_ADMISSIBILITY"
          }
        },
        {
          "contains": {
            "const": "READINESS_GATE_DOES_NOT_CERTIFY_LAWFULNESS"
          }
        },
        {
          "contains": {
            "const": "READINESS_GATE_DOES_NOT_CERTIFY_REGULATORY_COMPLIANCE"
          }
        },
        {
          "contains": {
            "const": "READINESS_GATE_DOES_NOT_CERTIFY_HIPAA_COMPLIANCE"
          }
        },
        {
          "contains": {
            "const": "READINESS_GATE_DOES_NOT_CERTIFY_MEDICAL_CORRECTNESS"
          }
        },
        {
          "contains": {
            "const": "READINESS_GATE_DOES_NOT_CERTIFY_CLINICAL_APPROPRIATENESS"
          }
        },
        {
          "contains": {
            "const": "READINESS_GATE_DOES_NOT_CERTIFY_UTILIZATION_MANAGEMENT_SUFFICIENCY"
          }
        },
        {
          "contains": {
            "const": "READINESS_GATE_DOES_NOT_REPLACE_INSTITUTIONAL_APPROVAL"
          }
        }
      ]
    },
    "live_ingestion_authorization_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authorization_state",
        "fork_issued_live_ingestion_authorization",
        "external_institutional_authorization_required",
        "institutional_live_ingestion_authorization_ref",
        "fork_does_not_validate_external_authorization_sufficiency"
      ],
      "properties": {
        "authorization_state": {
          "const": "NOT_ASSERTED_BY_FORK"
        },
        "fork_issued_live_ingestion_authorization": {
          "const": false
        },
        "external_institutional_authorization_required": {
          "const": true
        },
        "institutional_live_ingestion_authorization_ref": {
          "const": null
        },
        "fork_does_not_validate_external_authorization_sufficiency": {
          "const": true
        }
      }
    }
  }
}
