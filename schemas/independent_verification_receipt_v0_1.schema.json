{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://recomputableevidence.example/schemas/independent_verification_receipt_v0_1.schema.json",
  "title": "Fork Independent Verification Receipt v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "checker_id",
    "mode",
    "plan",
    "subject",
    "claim_admission",
    "assertions",
    "external_evidence",
    "independence_boundary",
    "result",
    "control_errors",
    "non_claims"
  ],
  "properties": {
    "checker_id": {"const": "FORK_INDEPENDENT_VERIFICATION_SURFACE_v0_1"},
    "mode": {"const": "CONTRIBUTION_VERIFICATION"},
    "plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plan_id", "path", "sha256"],
      "properties": {
        "plan_id": {"type": "string"},
        "path": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "base_commit",
        "base_tree",
        "candidate_commit",
        "candidate_tree",
        "merge_base",
        "changed_paths"
      ],
      "properties": {
        "repository": {"type": "string"},
        "base_commit": {"$ref": "#/definitions/sha1"},
        "base_tree": {"$ref": "#/definitions/sha1"},
        "candidate_commit": {"$ref": "#/definitions/sha1"},
        "candidate_tree": {"$ref": "#/definitions/sha1"},
        "merge_base": {"$ref": "#/definitions/sha1"},
        "changed_paths": {"type": "array", "items": {"type": "string"}}
      }
    },
    "claim_admission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expected",
        "observed",
        "matches_expected",
        "candidate_checkout",
        "candidate_code_execution",
        "raw_result_sha256"
      ],
      "properties": {
        "expected": {"$ref": "#/definitions/gate_result"},
        "observed": {"$ref": "#/definitions/gate_result"},
        "matches_expected": {"type": "boolean"},
        "candidate_checkout": {"const": "NONE"},
        "candidate_code_execution": {"const": "NONE"},
        "raw_result_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "assertions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["assertion_id", "type", "status", "evidence"],
        "properties": {
          "assertion_id": {"type": "string"},
          "type": {"type": "string"},
          "status": {"enum": ["SUPPORTED", "CONTRADICTED", "INCONCLUSIVE"]},
          "evidence": {"type": "object"}
        }
      }
    },
    "external_evidence": {"type": "array", "items": {"type": "object"}},
    "independence_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plan_origin",
        "candidate_tree_controls_plan",
        "human_verifier",
        "human_independent_review_recorded",
        "self_certification"
      ],
      "properties": {
        "plan_origin": {"const": "TRUSTED_VERIFIER_CONTROL_PLANE"},
        "candidate_tree_controls_plan": {"const": false},
        "human_verifier": {"type": "string"},
        "human_independent_review_recorded": {"const": false},
        "self_certification": {"const": "PROHIBITED"}
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ok",
        "verdict",
        "subject_binding_contradictions",
        "contradicted_assertion_count",
        "inconclusive_assertion_count",
        "control_error_count",
        "merge_effect",
        "repository_standing_effect",
        "experiment_execution_effect"
      ],
      "properties": {
        "ok": {"type": "boolean"},
        "verdict": {
          "enum": [
            "VERIFIED_WITHIN_DECLARED_SCOPE",
            "INVALIDATED_BY_RECOMPUTATION",
            "INCONCLUSIVE_EVIDENCE_GAP"
          ]
        },
        "subject_binding_contradictions": {"type": "array", "items": {"type": "object"}},
        "contradicted_assertion_count": {"type": "integer", "minimum": 0},
        "inconclusive_assertion_count": {"type": "integer", "minimum": 0},
        "control_error_count": {"type": "integer", "minimum": 0},
        "merge_effect": {"const": "NONE"},
        "repository_standing_effect": {"const": "NONE"},
        "experiment_execution_effect": {"const": "NONE"}
      }
    },
    "control_errors": {"type": "array", "items": {"type": "string"}},
    "non_claims": {"type": "array", "minItems": 1, "items": {"type": "string"}}
  },
  "definitions": {
    "sha1": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "path"],
      "properties": {
        "code": {"type": "string"},
        "path": {"type": "string"}
      }
    },
    "gate_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result_kind", "findings"],
      "properties": {
        "result_kind": {"type": ["string", "null"]},
        "findings": {"type": "array", "items": {"$ref": "#/definitions/finding"}}
      }
    }
  }
}
