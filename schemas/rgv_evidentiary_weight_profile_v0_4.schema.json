{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fork.example/schemas/rgv_evidentiary_weight_profile_v0_4.schema.json",
  "title": "RGV Evidentiary Weight Hardening Profile v0.4",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_type",
    "profile_version",
    "profile_scope",
    "canonicalization_profile",
    "verifier_binding",
    "seal_binding",
    "timestamp_anchor_ref",
    "provenance_binding",
    "profile_non_claims"
  ],
  "properties": {
    "record_type": {
      "const": "RGV_EVIDENTIARY_WEIGHT_PROFILE"
    },
    "profile_version": {
      "const": "0.4"
    },
    "profile_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base_rgv_version",
        "base_graph_bundle_version",
        "non_breaking_profile"
      ],
      "properties": {
        "base_rgv_version": {
          "const": "RGV_v0_3"
        },
        "base_graph_bundle_version": {
          "type": "string",
          "minLength": 1
        },
        "non_breaking_profile": {
          "const": true
        }
      }
    },
    "canonicalization_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonicalization_profile_id",
        "canonicalization_profile_type",
        "canonicalization_profile_state"
      ],
      "properties": {
        "canonicalization_profile_id": {
          "const": "RFC8785_JCS"
        },
        "canonicalization_profile_type": {
          "const": "CONST"
        },
        "canonicalization_profile_state": {
          "enum": [
            "DECLARED",
            "IMPLEMENTED_AND_VERIFIED"
          ]
        }
      }
    },
    "verifier_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "verifier_name",
        "verifier_version",
        "verifier_version_in_sealed_scope"
      ],
      "properties": {
        "verifier_name": {
          "const": "RGV"
        },
        "verifier_version": {
          "const": "RGV_v0_3"
        },
        "verifier_version_in_sealed_scope": {
          "const": true
        }
      }
    },
    "seal_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "seal_scope",
        "seal_algorithm",
        "declared_method",
        "signer_identity",
        "non_repudiation"
      ],
      "properties": {
        "seal_scope": {
          "enum": [
            "BUNDLE_ONLY",
            "RESULT_ONLY",
            "BUNDLE_AND_RESULT_INDEPENDENT",
            "COMPOUND_BUNDLE_RESULT"
          ]
        },
        "seal_algorithm": {
          "const": "SHA256"
        },
        "declared_method": {
          "const": "SHA256_OVER_RFC8785_JCS_CANONICAL_JSON"
        },
        "bundle_digest": {
          "$ref": "#/$defs/sha256_digest"
        },
        "result_digest": {
          "$ref": "#/$defs/sha256_digest"
        },
        "compound_digest": {
          "$ref": "#/$defs/sha256_digest"
        },
        "compound_digest_ordering": {
          "enum": [
            "BUNDLE_CANONICAL_JSON_THEN_RESULT_CANONICAL_JSON"
          ]
        },
        "signer_identity": {
          "$ref": "#/$defs/establishment_state"
        },
        "non_repudiation": {
          "$ref": "#/$defs/establishment_state"
        }
      }
    },
    "timestamp_anchor_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timestamp_anchor_state",
        "anchored_digest_scope"
      ],
      "properties": {
        "timestamp_anchor_state": {
          "enum": [
            "PASS",
            "NOT_CHECKED",
            "NOT_ESTABLISHED"
          ]
        },
        "anchored_digest_scope": {
          "enum": [
            "BUNDLE_ONLY",
            "RESULT_ONLY",
            "BUNDLE_AND_RESULT_INDEPENDENT",
            "COMPOUND_BUNDLE_RESULT",
            "NOT_ESTABLISHED"
          ]
        },
        "timestamp_anchor_artifact_ref": {
          "type": "string"
        }
      }
    },
    "provenance_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tier_order_weakest_to_strongest",
        "cbc_provenance",
        "minimum_provenance_tier",
        "minimum_rollup_rule"
      ],
      "properties": {
        "tier_order_weakest_to_strongest": {
          "type": "array",
          "prefixItems": [
            { "const": "UNRESOLVED" },
            { "const": "GENERATED" },
            { "const": "INTERPRETIVE" },
            { "const": "ATTRIBUTED" },
            { "const": "DOCUMENTED" }
          ],
          "items": false,
          "minItems": 5,
          "maxItems": 5
        },
        "cbc_provenance": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "cbc_id",
              "declared_provenance_tier"
            ],
            "properties": {
              "cbc_id": {
                "type": "string",
                "minLength": 1
              },
              "declared_provenance_tier": {
                "$ref": "#/$defs/provenance_tier"
              }
            }
          }
        },
        "minimum_provenance_tier": {
          "$ref": "#/$defs/provenance_tier"
        },
        "minimum_rollup_rule": {
          "const": "BUNDLE_PROVENANCE_CANNOT_EXCEED_LOWEST_CONFIDENCE_CBC_NODE"
        }
      }
    },
    "profile_non_claims": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "non_claim_id",
          "statement"
        ],
        "properties": {
          "non_claim_id": {
            "type": "string",
            "minLength": 1
          },
          "statement": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "provenance_tier": {
      "enum": [
        "DOCUMENTED",
        "ATTRIBUTED",
        "INTERPRETIVE",
        "GENERATED",
        "UNRESOLVED"
      ]
    },
    "sha256_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "establishment_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state"
      ],
      "properties": {
        "state": {
          "enum": [
            "ESTABLISHED",
            "NOT_ESTABLISHED",
            "NOT_CHECKED"
          ]
        },
        "basis": {
          "type": "string"
        }
      }
    }
  }
}
