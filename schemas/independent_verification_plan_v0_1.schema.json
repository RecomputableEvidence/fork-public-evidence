{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://recomputableevidence.example/schemas/independent_verification_plan_v0_1.schema.json",
  "title": "Fork Independent Verification Plan v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "plan_id",
    "schema_version",
    "scope_statement",
    "subject",
    "expected_claim_admission",
    "assertions",
    "external_evidence",
    "independence_boundary"
  ],
  "properties": {
    "plan_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9_.-]{4,127}$"},
    "schema_version": {"const": "0.1"},
    "scope_statement": {"type": "string", "minLength": 1},
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "base_commit",
        "base_tree",
        "candidate_commit",
        "candidate_tree",
        "expected_merge_base"
      ],
      "properties": {
        "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
        "base_commit": {"$ref": "#/definitions/sha1"},
        "base_tree": {"$ref": "#/definitions/sha1"},
        "candidate_commit": {"$ref": "#/definitions/sha1"},
        "candidate_tree": {"$ref": "#/definitions/sha1"},
        "expected_merge_base": {"$ref": "#/definitions/sha1"}
      }
    },
    "expected_claim_admission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result_kind", "findings", "interpretation"],
      "properties": {
        "result_kind": {"enum": ["STRUCTURAL_PASS", "CLAIM_ADMISSION_GATE_FAILED"]},
        "findings": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "path"],
            "properties": {
              "code": {"type": "string", "pattern": "^[A-Z0-9_]+$"},
              "path": {"$ref": "#/definitions/path"}
            }
          }
        },
        "interpretation": {"type": "string", "minLength": 1}
      }
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/definitions/assertion"}
    },
    "external_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_id", "kind", "reference", "observed_state", "authority_effect"],
        "properties": {
          "evidence_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9_.-]{2,127}$"},
          "kind": {"enum": ["GITHUB_ACTIONS_RUN", "PULL_REQUEST_STATE", "REVIEW_RECORD", "OTHER"]},
          "reference": {"type": "string", "minLength": 1},
          "observed_state": {"type": "string", "minLength": 1},
          "authority_effect": {"const": "OBSERVATION_ONLY"}
        }
      }
    },
    "independence_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plan_origin",
        "candidate_tree_controls_plan",
        "human_verifier",
        "self_certification_prohibited"
      ],
      "properties": {
        "plan_origin": {"const": "TRUSTED_VERIFIER_CONTROL_PLANE"},
        "candidate_tree_controls_plan": {"const": false},
        "human_verifier": {"type": "string", "minLength": 1},
        "self_certification_prohibited": {"const": true}
      }
    }
  },
  "definitions": {
    "sha1": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)[^\\u0000-\\u001f]+$"
    },
    "assertion": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["assertion_id", "type", "expected_paths"],
          "properties": {
            "assertion_id": {"$ref": "#/definitions/assertion_id"},
            "type": {"const": "CHANGED_PATH_SET_EQUALS"},
            "expected_paths": {
              "type": "array",
              "uniqueItems": true,
              "items": {"$ref": "#/definitions/path"}
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["assertion_id", "type", "path"],
          "properties": {
            "assertion_id": {"$ref": "#/definitions/assertion_id"},
            "type": {"enum": ["PATH_PRESENT", "PATH_ABSENT", "UNCHANGED_FROM_BASE", "WORKFLOW_HARDENED"]},
            "path": {"$ref": "#/definitions/path"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["assertion_id", "type", "path", "expected_sha256"],
          "properties": {
            "assertion_id": {"$ref": "#/definitions/assertion_id"},
            "type": {"const": "SHA256_EQUALS"},
            "path": {"$ref": "#/definitions/path"},
            "expected_sha256": {"$ref": "#/definitions/sha256"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["assertion_id", "type", "path", "base_path"],
          "properties": {
            "assertion_id": {"$ref": "#/definitions/assertion_id"},
            "type": {"const": "ARCHIVE_EQUALS_BASE_PATH"},
            "path": {"$ref": "#/definitions/path"},
            "base_path": {"$ref": "#/definitions/path"}
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["assertion_id", "type", "path", "pointer", "expected"],
          "properties": {
            "assertion_id": {"$ref": "#/definitions/assertion_id"},
            "type": {"const": "JSON_POINTER_EQUALS"},
            "path": {"$ref": "#/definitions/path"},
            "pointer": {"type": "string", "pattern": "^(?:$|/)"},
            "expected": {}
          }
        }
      ]
    },
    "assertion_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9_.-]{2,127}$"}
  }
}
