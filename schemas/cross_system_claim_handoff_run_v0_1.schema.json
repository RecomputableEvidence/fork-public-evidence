{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recomputableevidence.example/schemas/cross_system_claim_handoff_run_v0_1.schema.json",
  "title": "Cross-System Claim Handoff Receiver Run v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receiver_run_id",
    "schema_version",
    "experiment_id",
    "scenario_id",
    "condition",
    "receiver_class_id",
    "replicate_id",
    "pairing_key",
    "input_artifacts",
    "handoff_artifact_present",
    "receiver_configuration",
    "access_path",
    "execution",
    "raw_output",
    "terminal_disposition",
    "excluded",
    "non_claims"
  ],
  "properties": {
    "receiver_run_id": {
      "type": "string",
      "pattern": "^CSH-RUN-"
    },
    "schema_version": {
      "const": "v0.1"
    },
    "experiment_id": {
      "const": "cross_system_claim_handoff_v0_1"
    },
    "scenario_id": {
      "type": "string"
    },
    "condition": {
      "enum": [
        "control_h0",
        "instrumented_h1"
      ]
    },
    "receiver_class_id": {
      "type": "string"
    },
    "replicate_id": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3
    },
    "pairing_key": {
      "type": "string",
      "minLength": 1
    },
    "input_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "handoff_artifact_present": {
      "type": "boolean"
    },
    "receiver_configuration": {
      "type": "object",
      "required": [
        "provider",
        "model_or_system",
        "version",
        "parameters"
      ],
      "properties": {
        "provider": {
          "type": "string"
        },
        "model_or_system": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "parameters": {
          "type": "object"
        }
      }
    },
    "access_path": {
      "type": "object",
      "required": [
        "retrieval_state",
        "interpreter_state"
      ],
      "properties": {
        "retrieval_state": {
          "enum": [
            "complete",
            "partial",
            "failed",
            "transformed"
          ]
        },
        "interpreter_state": {
          "enum": [
            "compatible",
            "incompatible",
            "not_applicable"
          ]
        }
      }
    },
    "execution": {
      "type": "object",
      "required": [
        "started_at_utc",
        "ended_at_utc",
        "status",
        "error"
      ],
      "properties": {
        "started_at_utc": {
          "type": [
            "string",
            "null"
          ]
        },
        "ended_at_utc": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "enum": [
            "successful",
            "failed",
            "unavailable",
            "not_started"
          ]
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "raw_output": {
      "type": "object",
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "sha256": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "terminal_disposition": {
      "enum": [
        "completed_classifiable",
        "completed_unclassifiable",
        "excluded",
        "execution_unavailable",
        "not_started"
      ]
    },
    "excluded": {
      "type": "object",
      "required": [
        "value",
        "reason"
      ],
      "properties": {
        "value": {
          "type": "boolean"
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "condition": {
            "const": "instrumented_h1"
          }
        }
      },
      "then": {
        "properties": {
          "handoff_artifact_present": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "condition": {
            "const": "control_h0"
          }
        }
      },
      "then": {
        "properties": {
          "handoff_artifact_present": {
            "const": false
          }
        }
      }
    }
  ]
}
