      "properties": {
        "ccec_id": {
          "type": "string",
          "minLength": 1
        },
        "ccec_contract_version": {
          "const": "0.1"
        },
        "ccec_hash_sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "external_system": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system_id",
        "system_type",
        "system_name",
        "owner_organization"
