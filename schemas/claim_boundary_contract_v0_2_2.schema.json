{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://recomputableevidence.example/schemas/claim_boundary_contract_v0_2_2.schema.json",
  "title": "Claim Boundary Contract v0.2.2",
  "description": "Final precision hardening of CBC v0.2.x. Records source-side claim boundaries without asserting source truth, legal sufficiency, compliance sufficiency, deployment readiness, policy correctness, source completeness, or runtime enforcement.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_type",
    "cbc_version",
    "claim_id",
    "artifact_name",
    "artifact_type",
    "timestamp_utc",
    "verification_status",
    "verification_scope",
    "scope",
    "positive_claims",
    "non_claims",
    "upstream_claims_received",
    "upstream_claims_relied_on",
    "upstream_claims_rejected",
    "transitivity_policy",
    "issuer_semantics_authority",
    "sealed_at",
    "evidence_refs",
    "known_gaps",
    "human_or_institutional_decisions_remaining"
  ],
  "properties": {
    "record_type": {
      "const": "CLAIM_BOUNDARY_CONTRACT"
    },
    "cbc_version": {
      "const": "CBC_v0_2_2"
    },
    "claim_id": {
      "$ref": "#/$defs/non_empty_string"
    },
    "artifact_name": {
      "$ref": "#/$defs/non_empty_string"
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "RUNTIME_EVENT_RECORD",
        "BENCHMARK_EXECUTION_RECORD",
        "DOWNSTREAM_CLAIM_BOUNDARY",
        "POLICY_ASSOCIATION_RECORD",
        "OTHER"
      ]
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "verification_status": {
      "type": "string",
      "enum": [
        "PASS",
        "FAIL",
        "NOT_CHECKED",
        "INDETERMINATE"
      ]
    },
    "verification_scope": {
      "type": "string",
      "enum": [
        "RECORD_INTEGRITY_ONLY",
        "BOUNDARY_STRUCTURE_ONLY",
        "RECORD_INTEGRITY_AND_BOUNDARY_STRUCTURE_ONLY",
        "NOT_CHECKED"
      ]
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "positive_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/positive_claim"
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_claim"
      }
    },
    "upstream_claims_received": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/upstream_claim"
      }
    },
    "upstream_claims_relied_on": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/upstream_claim"
      }
    },
    "upstream_claims_rejected": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/upstream_claim"
      }
    },
    "transitivity_policy": {
      "$ref": "#/$defs/transitivity_policy"
    },
    "issuer_semantics_authority": {
      "$ref": "#/$defs/issuer_semantics_authority"
    },
    "sealed_at": {
      "$ref": "#/$defs/sealed_at"
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/evidence_ref"
      }
    },
    "known_gaps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/known_gap"
      }
    },
    "human_or_institutional_decisions_remaining": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/remaining_decision"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "verification_status": {
            "const": "PASS"
          }
        },
        "required": [
          "verification_status"
        ]
      },
      "then": {
        "properties": {
          "verification_scope": {
            "const": "RECORD_INTEGRITY_AND_BOUNDARY_STRUCTURE_ONLY"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "verification_status": {
            "const": "NOT_CHECKED"
          }
        },
        "required": [
          "verification_status"
        ]
      },
      "then": {
        "properties": {
          "verification_scope": {
            "const": "NOT_CHECKED"
          }
        }
      }
    }
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_type",
        "identifier",
        "environment",
        "description"
      ],
      "properties": {
        "object_type": {
          "$ref": "#/$defs/non_empty_string"
        },
        "identifier": {
          "$ref": "#/$defs/non_empty_string"
        },
        "environment": {
          "type": "string",
          "enum": [
            "DEVELOPMENT",
            "TEST",
            "PILOT",
            "PRODUCTION",
            "REVIEW",
            "OTHER"
          ]
        },
        "description": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "positive_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "statement_id",
        "statement",
        "limited_to"
      ],
      "properties": {
        "statement_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "statement": {
          "$ref": "#/$defs/non_empty_string"
        },
        "limited_to": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "non_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "non_claim_id",
        "statement",
        "must_travel_downstream"
      ],
      "properties": {
        "non_claim_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "statement": {
          "$ref": "#/$defs/non_empty_string"
        },
        "must_travel_downstream": {
          "const": true
        }
      },
      "description": "A source-side non-claim that travels with the CBC boundary. This prevents downstream consumers from silently converting bounded evidence into broader conclusions."
    },
    "upstream_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "source_artifact_id",
        "claim_text",
        "verification_state",
        "verification_scope",
        "preserved_non_claim_ids"
      ],
      "properties": {
        "claim_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_artifact_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "claim_text": {
          "$ref": "#/$defs/non_empty_string"
        },
        "verification_state": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL",
            "NOT_CHECKED",
            "INDETERMINATE"
          ]
        },
        "verification_scope": {
          "$ref": "#/$defs/non_empty_string"
        },
        "preserved_non_claim_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true
        }
      },
      "description": "A bounded upstream claim reference. v0.2.2 relational tests reject duplicate received claim IDs and require preserved upstream non-claims relied on by this CBC to remain represented in the current CBC."
    },
    "transitivity_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "statement"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "LOCAL_ONLY",
            "SCOPED",
            "CONDITIONAL",
            "NON_TRANSITIVE"
          ]
        },
        "statement": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "issuer_semantics_authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "authority",
        "statement"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "issuer_defined",
            "external_taxonomy",
            "regulatory_framework",
            "other"
          ]
        },
        "authority": {
          "$ref": "#/$defs/non_empty_string"
        },
        "statement": {
          "$ref": "#/$defs/non_empty_string"
        }
      },
      "description": "Records who defines the semantics of this boundary. It does not confer legal, regulatory, or institutional sufficiency."
    },
    "sealed_at": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timestamp_utc",
        "sealed_by",
        "seal_algorithm",
        "payload_sha256"
      ],
      "properties": {
        "timestamp_utc": {
          "type": "string",
          "format": "date-time"
        },
        "sealed_by": {
          "$ref": "#/$defs/sealed_by"
        },
        "seal_algorithm": {
          "const": "SHA256"
        },
        "payload_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "sealed_by": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "type": {
          "type": "string",
          "enum": [
            "SYSTEM",
            "HUMAN",
            "INSTITUTION",
            "OTHER"
          ]
        },
        "system_id": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id",
        "uri",
        "sha256",
        "description"
      ],
      "properties": {
        "ref_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "uri": {
          "$ref": "#/$defs/non_empty_string"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "description": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "known_gap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gap_id",
        "description",
        "effect"
      ],
      "properties": {
        "gap_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "description": {
          "$ref": "#/$defs/non_empty_string"
        },
        "effect": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "remaining_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "description",
        "responsible_role"
      ],
      "properties": {
        "decision_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "description": {
          "$ref": "#/$defs/non_empty_string"
        },
        "responsible_role": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
