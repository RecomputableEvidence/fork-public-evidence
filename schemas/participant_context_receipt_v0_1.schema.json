{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_access_level": {
      "enum": [
        "NONE",
        "P1_DESCRIPTION",
        "P2_RENDERED_OR_PARTIAL",
        "P3_RAW_FILE",
        "P4_EXECUTION"
      ],
      "type": "string"
    },
    "attribution_status": {
      "enum": [
        "NOT_REQUESTED",
        "REQUESTED",
        "AUTHORIZED",
        "RESTRICTED",
        "NOT_AUTHORIZED",
        "WITHDRAWN"
      ],
      "type": "string"
    },
    "collaboration_interest_status": {
      "enum": [
        "NONE_DECLARED",
        "PRESENT",
        "POTENTIAL",
        "UNKNOWN"
      ],
      "type": "string"
    },
    "commercial_interest_status": {
      "enum": [
        "NONE_DECLARED",
        "PRESENT",
        "POTENTIAL",
        "UNKNOWN"
      ],
      "type": "string"
    },
    "compensation_status": {
      "enum": [
        "NONE",
        "PAID",
        "OFFERED",
        "DECLINED",
        "UNKNOWN"
      ],
      "type": "string"
    },
    "correction_status": {
      "enum": [
        "NONE",
        "CORRECTED",
        "DISPUTED",
        "PENDING"
      ],
      "type": "string"
    },
    "execution_access": {
      "type": "boolean"
    },
    "interaction_channel": {
      "enum": [
        "LINKEDIN",
        "EMAIL",
        "GITHUB",
        "VIDEO_CALL",
        "IN_PERSON",
        "OTHER"
      ],
      "type": "string"
    },
    "interaction_role": {
      "maxLength": 512,
      "minLength": 1,
      "type": "string"
    },
    "interaction_visibility": {
      "enum": [
        "PUBLIC",
        "PRIVATE",
        "OFF_RECORD",
        "MIXED"
      ],
      "type": "string"
    },
    "non_endorsement_status": {
      "enum": [
        "EXPLICITLY_NOT_ENDORSED",
        "NO_ENDORSEMENT_INFERABLE",
        "EXPLICIT_ENDORSEMENT_AUTHORIZED"
      ],
      "type": "string"
    },
    "notes": {
      "maxLength": 4096,
      "minLength": 1,
      "type": "string"
    },
    "paraphrase_status": {
      "enum": [
        "NOT_REQUESTED",
        "AUTHORIZED",
        "RESTRICTED",
        "NOT_AUTHORIZED",
        "WITHDRAWN"
      ],
      "type": "string"
    },
    "participant_context_id": {
      "maxLength": 256,
      "minLength": 5,
      "pattern": "^PCR-[A-Za-z0-9._:-]+$",
      "type": "string"
    },
    "participant_identifier": {
      "maxLength": 512,
      "type": [
        "string",
        "null"
      ]
    },
    "participant_identifier_type": {
      "enum": [
        "NAMED",
        "PSEUDONYMOUS",
        "ANONYMOUS",
        "ORGANIZATIONAL"
      ],
      "type": "string"
    },
    "prior_relationship_status": {
      "enum": [
        "NONE",
        "PROFESSIONAL_CONTACT",
        "COLLABORATOR",
        "COMMERCIAL",
        "OTHER",
        "UNKNOWN"
      ],
      "type": "string"
    },
    "quotation_status": {
      "enum": [
        "NOT_REQUESTED",
        "AUTHORIZED",
        "RESTRICTED",
        "NOT_AUTHORIZED",
        "WITHDRAWN"
      ],
      "type": "string"
    },
    "recorded_at": {
      "format": "date-time",
      "maxLength": 64,
      "minLength": 1,
      "type": "string"
    },
    "relationship_to_fork": {
      "enum": [
        "INDEPENDENT_TECHNICAL_REVIEWER",
        "EXTERIOR_OBSERVER",
        "PROFESSIONAL_PEER",
        "POTENTIAL_COLLABORATOR",
        "COMMERCIAL_PROSPECT",
        "DESIGN_PARTNER_CANDIDATE",
        "CONTRIBUTOR",
        "ADVISOR",
        "UNKNOWN_OR_UNDECLARED"
      ],
      "type": "string"
    },
    "schema_version": {
      "const": "0.1"
    },
    "solicitation_status": {
      "enum": [
        "SOLICITED",
        "UNSOLICITED",
        "MIXED",
        "UNKNOWN"
      ],
      "type": "string"
    },
    "withdrawal_status": {
      "enum": [
        "NOT_WITHDRAWN",
        "WITHDRAWN_UNPUBLISHED",
        "WITHDRAWN_WITH_PUBLIC_CORRECTION",
        "PARTIALLY_WITHDRAWN"
      ],
      "type": "string"
    }
  },
  "required": [
    "participant_context_id",
    "schema_version",
    "participant_identifier",
    "participant_identifier_type",
    "relationship_to_fork",
    "interaction_role",
    "interaction_channel",
    "interaction_visibility",
    "solicitation_status",
    "prior_relationship_status",
    "compensation_status",
    "commercial_interest_status",
    "collaboration_interest_status",
    "artifact_access_level",
    "execution_access",
    "attribution_status",
    "quotation_status",
    "paraphrase_status",
    "correction_status",
    "withdrawal_status",
    "non_endorsement_status",
    "recorded_at",
    "notes"
  ],
  "title": "Fork Participant Context Receipt v0.1",
  "type": "object"
}
