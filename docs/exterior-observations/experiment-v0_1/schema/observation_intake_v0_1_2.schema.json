{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/RecomputableEvidence/fork-public-evidence/docs/exterior-observations/experiment-v0_1/schema/observation_intake_v0_1_2.schema.json",
  "title": "Exterior Observance Observation Intake v0.1.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "identifier",
    "observer",
    "date",
    "interaction_type",
    "classification",
    "scope_requested",
    "scope_performed",
    "execution_status",
    "access_modes",
    "artifacts_requested",
    "artifacts_inspected",
    "endorsement",
    "limitations",
    "non_endorsement_statement",
    "non_endorsement_attestation"
  ],
  "properties": {
    "identifier": {
      "type": "string",
      "minLength": 1
    },
    "observer": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "interaction_type": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "technical recomputation",
          "architectural observation",
          "governance observation",
          "interoperability observation",
          "semantic pressure observation",
          "upstream admission observation",
          "downstream procurement observation",
          "scope declination",
          "consulting scope signal",
          "access constraint observation",
          "retrieval fidelity observation",
          "meta-observation"
        ]
      },
      "uniqueItems": true
    },
    "classification": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "boundary interpretation",
          "semantic pressure surface",
          "upstream admission",
          "downstream procurement",
          "role separation",
          "consulting scope signal",
          "failure-case proposal",
          "navigation friction",
          "LLM accessibility gap",
          "retrieval fidelity limitation",
          "plaintext packaging requirement",
          "source substitution",
          "stale or partial retrieval",
          "surface misattribution",
          "prompt echo risk",
          "overclaim risk",
          "instrumentation gap",
          "schema proposal",
          "retrieval fidelity sufficient",
          "hash comparison",
          "source identity confirmation",
          "input integrity gap",
          "hostile endorsement injection",
          "non-endorsement scrubbing",
          "coding accumulation risk",
          "manifest proposal"
        ]
      },
      "uniqueItems": true
    },
    "scope_requested": {
      "type": "string",
      "minLength": 1
    },
    "scope_performed": {
      "type": "string",
      "minLength": 1
    },
    "execution_status": {
      "type": "string",
      "enum": [
        "not_performed",
        "performed",
        "attempted_failed",
        "partial",
        "unknown"
      ]
    },
    "access_modes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "github_rendered",
        "raw",
        "plaintext_packet",
        "repository_clone",
        "pasted_content"
      ],
      "properties": {
        "github_rendered": {
          "type": "string",
          "enum": ["succeeded", "failed", "not_attempted"]
        },
        "raw": {
          "type": "string",
          "enum": ["succeeded", "failed", "not_attempted"]
        },
        "plaintext_packet": {
          "type": "string",
          "enum": ["succeeded", "failed", "not_attempted"]
        },
        "repository_clone": {
          "type": "string",
          "enum": ["succeeded", "failed", "not_attempted"]
        },
        "pasted_content": {
          "type": "string",
          "enum": ["succeeded", "failed", "not_attempted"]
        }
      }
    },
    "artifacts_requested": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifacts_inspected": {
      "type": "array",
      "items": { "type": "string" }
    },
    "endorsement": {
      "type": "string",
      "enum": ["none"]
    },
    "limitations": {
      "type": "string",
      "minLength": 1
    },
    "non_endorsement_statement",
    "non_endorsement_attestation": {
      "type": "string",
      "minLength": 1
    }
  }
}
